{
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  "search.exclude": { "**/api/auth/**": true },

  "files.readonlyInclude": {
    "**/core/**": true,

    "**/app/api/auth/**": true,
    "**/app/layout.tsx": true,
    "**/app/dashboard/layout.tsx": true,

    "**/modules/auth/**": true,
    "**/modules/activity/**": true
  },

  "files.readonlyExclude": {
    "**/modules/activity/config.tsx": true
  },

  "js/ts.preferences.autoImportFileExcludePatterns": [
    "next/router",
    "@base-ui/react"
  ],

  "js/ts.preferences.importModuleSpecifier": "shortest"
}
